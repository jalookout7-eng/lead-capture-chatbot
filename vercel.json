{
  "version": 2,
  "builds": [
    { "src": "api/index.js",  "use": "@vercel/node"   },
    { "src": "public/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)",       "dest": "/api/index.js"            },
    { "src": "/admin",          "dest": "/public/admin/index.html" },
    { "src": "/admin/",         "dest": "/public/admin/index.html" },
    { "src": "/widget.html",    "dest": "/public/widget.html"      },
    { "src": "/sw.js",          "dest": "/public/sw.js"            },
    { "src": "/(.*)",           "dest": "/public/$1"               }
  ]
}